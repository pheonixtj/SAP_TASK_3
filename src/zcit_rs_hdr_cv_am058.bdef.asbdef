projection;
strict ( 2 );
use draft;
define behavior for ZCIT_RS_HDR_CV_AM058 alias Header
{
use create;
use update;
use delete;
use action Edit;
use action Activate;
use action Discard;
use action Resume;
use action Prepare;
use action markAsPaid;
use association _Items { create; with draft; }
}
define behavior for ZCIT_RS_ITM_CV_AM058 alias Item
{
use update;
use delete;
use association _Header { with draft; }
}